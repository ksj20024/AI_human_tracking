# PyCharm 및 IDE 설정 파일 제외
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 파이썬 가상환경 및 캐시 파일
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ======================================================================
# 📂 [⚠️ 핵심] 폴더 구조(뼈대)는 깃허브에 올리되, 내부 대용량 내용물만 무시
# ======================================================================

# 1. MOT17 원본 데이터 폴더 내부 비우기
data/MOT17/*
!data/MOT17/.gitkeep

# 2. MOT20 원본 데이터 폴더 내부 비우기
data/MOT20/*
!data/MOT20/.gitkeep

# 3. 고속 심볼릭 링크로 가공될 출력 폴더 내부 비우기
data/processed_mot/*
!data/processed_mot/.gitkeep

# 4. 학습 완료 후 생성될 챔피언 가중치 폴더 내부 비우기
weights/*
!weights/.gitkeep

# 5. 시나리오 실험 결과 리포트가 쌓일 폴더 내부 비우기
results/*
!results/.gitkeep

# ======================================================================
# 🧠 Ultralytics 가중치 다운로드 및 실행 임시 파일 완전히 무시
# ======================================================================
yolo11n.pt
rtdetr-l.pt
runs/
runs_tuning_yolo/
runs_tuning_detr/
config/temp_bytetrack_*.yaml
*.log